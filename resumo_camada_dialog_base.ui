   <string notr="true">QDialog {
    background-color: #f4f7fb;
}

QFrame#headerFrame {
    background-color: #1f4e79;
    border-radius: 10px;
}

QLabel#titleLabel {
    color: white;
    font-size: 20px;
    font-weight: bold;
}

QLabel#subtitleLabel,
QLabel#dataGeracaoLabel {
    color: #d9e6f2;
    font-size: 11px;
}

QGroupBox {
    font-weight: bold;
    font-size: 12px;
    color: #1f2d3d;
    border: 1px solid #d8e1ea;
    border-radius: 10px;
    margin-top: 12px;
    background-color: white;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 4px 0 4px;
}

QLabel {
    color: #243447;
    font-size: 12px;
}

QLabel[role="caption"] {
    color: #6b7c93;
    font-size: 11px;
}

QLabel[role="value"] {
    color: #102a43;
    font-size: 13px;
    font-weight: bold;
}

QPushButton {
    min-height: 34px;
    border-radius: 8px;
    padding: 6px 14px;
    font-weight: bold;
}

QPushButton#btnExportarPdf {
    background-color: #1f4e79;
    color: white;
    border: 1px solid #1f4e79;
}

QPushButton#btnExportarPdf:hover {
    background-color: #173a5c;
}

QPushButton#btnExportarCsv {
    background-color: white;
    color: #1f4e79;
    border: 1px solid #b8c7d9;
}

QPushButton#btnExportarCsv:hover {
    background-color: #eef4fa;
}

QPushButton#btnFechar {
    background-color: #f1f3f5;
    color: #243447;
    border: 1px solid #d5dce3;
}

QPushButton#btnFechar:hover {
    background-color: #e7ebf0;
}</string>
